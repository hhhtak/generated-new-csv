{
  "name": "csv-converter",
  "version": "1.0.0",
  "description": "A flexible CSV transformation tool with configurable rules",
  "main": "dist/index.js",
  "bin": {
    "csv-converter": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/cli.ts",
    "web": "ts-node src/web-server.ts",
    "start": "node dist/web-server.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src/**/*.ts",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "csv",
    "converter",
    "transformation",
    "data-processing",
    "encoding",
    "sequence-columns",
    "data-deletion"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "commander": "^12.1.0",
    "csv-parser": "^3.0.0",
    "express": "^4.22.1",
    "iconv-lite": "^0.7.2",
    "multer": "^2.0.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/iconv-lite": "^0.0.1",
    "@types/jest": "^29.5.14",
    "@types/multer": "^2.0.0",
    "@types/node": "^22.10.5",
    "@typescript-eslint/eslint-plugin": "^8.19.1",
    "@typescript-eslint/parser": "^8.19.1",
    "eslint": "^9.18.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2"
  }
}
